# Copia este archivo a ".env" y rellena los valores reales.
# El archivo ".env" está en .gitignore: nunca se sube al repo.

# ── Base de datos (PostgreSQL) — obligatorias ──
DB_USER=postgres
DB_PASSWORD=tu_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sires

# ── Nivel de log — opcional (por defecto INFO) ──
# Valores válidos: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ── Credenciales LOINC — opcionales ──
# Solo necesarias para descargar el catálogo LOINC (Basic Auth).
# Si las dejas vacías, ese catálogo simplemente no se autentica.
LOINC_USER=
LOINC_PASSWORD=
